# GPPL Enterprise Asset Management System — Environment Variables
# Copy this file to .env and fill in your values

FLASK_ENV=development
SECRET_KEY=gppl-eams-secret-key-change-in-production-use-random-64-chars
JWT_SECRET_KEY=gppl-jwt-secret-change-in-production-use-random-64-chars
SUPER_ADMIN_LOGIN_ID=superadmin@gppl.in
SUPER_ADMIN_PASSWORD=SuperAdmin@1234

# Database — SQLite (default, no install needed)
# To switch to PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/gppl_eams
DATABASE_URL=sqlite:///gppl_eams.db

# Mail (optional — leave empty to disable email notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@gppl.in

# CORS — comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Redis (optional — for rate limiting, leave as memory:// for dev)
REDIS_URL=memory://

# Frontend URL (for password reset links in emails)
FRONTEND_URL=http://localhost:5173
